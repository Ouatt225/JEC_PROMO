# ── Obligatoire ──────────────────────────────────────────────────────────────

# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changez-moi

# Mot de passe de la base de données PostgreSQL
DB_PASSWORD=changez-moi

# ── Optionnel (valeurs par défaut) ───────────────────────────────────────────

DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=sygepe_db
DB_USER=postgres
DB_HOST=localhost
DB_PORT=5432

# Laisser la valeur par défaut pour un Redis local
REDIS_URL=redis://127.0.0.1:6379/1

# ── E-mail (optionnel — console backend si DEBUG=True) ───────────────────────

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Compte Gmail (ou autre SMTP) utilisé pour l'envoi
EMAIL_HOST_USER=votre-adresse@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-application
DEFAULT_FROM_EMAIL=SYGEPE <noreply@sygepe.ci>
