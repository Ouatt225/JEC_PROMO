# Copiez ce fichier en .env et remplissez les valeurs
# cp .env.example .env

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_NAME=sygepe_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
